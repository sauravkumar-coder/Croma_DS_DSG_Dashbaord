# Copy this file to .env and fill in your values before running docker compose up.

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Leave empty to run on built-in mock data (no MongoDB needed).
# Example (Atlas): mongodb+srv://user:pass@cluster.mongodb.net/ds_dsg_tracker
MONGO_URI=

DATABASE_NAME=ds_dsg_tracker

# ── Brand filter ───────────────────────────────────────────────────────────────
BRAND_ID=brand_007
BRAND_USES_DAILY_SALES=true

# ── Mode ───────────────────────────────────────────────────────────────────────
# true  = serve mock data from JSON files (no MongoDB required)
# false = query MongoDB (MONGO_URI must be set)
USE_MOCK_DATA=true

ENVIRONMENT=production
