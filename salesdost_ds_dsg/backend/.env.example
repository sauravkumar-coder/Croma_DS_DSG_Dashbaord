# ── MongoDB ────────────────────────────────────────────────────────────────────
# Required in production (ENVIRONMENT=production, USE_MOCK_DATA=false).
# Leave empty to run in mock mode (USE_MOCK_DATA=true).
# Example (Atlas): mongodb+srv://user:pass@cluster.mongodb.net/zoppertrack
MONGO_URI=

DATABASE_NAME=ds_dsg_tracker

# ── Brand filter ────────────────────────────────────────────────────────────────
# Only this brand's data is shown in the dashboard.
# brand_007 = DSDSG / Croma brand.
BRAND_ID=brand_007

# Set to true when the brand stores revenue in dailySales (not monthlySales).
# brand_007 uses dailySales; set false if that changes.
BRAND_USES_DAILY_SALES=true

# ── Collection names ────────────────────────────────────────────────────────────
# Must match the actual collection names in MongoDB.
# Only override if your MongoDB collection names differ from the defaults.
STORE_COLLECTION=Store
BRAND_COLLECTION=Brand
CATEGORY_COLLECTION=Category
SALES_RECORD_COLLECTION=SalesRecord
STORE_TARGET_COLLECTION=StoreTarget
STORE_BRAND_COLLECTION=StoreBrand

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development: ALLOWED_ORIGINS=*
# Production:  ALLOWED_ORIGINS=https://your-dashboard.example.com
ALLOWED_ORIGINS=*

# ── Feature flags ───────────────────────────────────────────────────────────────
# USE_MOCK_DATA=true  → serve from backend/mock/*.json (no MongoDB needed)
# USE_MOCK_DATA=false → query MongoDB (MONGO_URI must be set)
#
# IMPORTANT: Setting ENVIRONMENT=production and USE_MOCK_DATA=false without
# MONGO_URI will cause the server to refuse startup with a clear error message.
USE_MOCK_DATA=true

# Set to "production" for AWS / cloud deployments.
ENVIRONMENT=development
