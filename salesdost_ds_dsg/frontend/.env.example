# ── Backend API URL ─────────────────────────────────────────────────────────────
# Development: leave unset — Vite dev server proxies /api/* to http://localhost:8000
# Production:  set to the full URL of your FastAPI backend (no trailing slash)
# Example (AWS EC2):   VITE_API_URL=https://api.your-dashboard.example.com
# Example (same host): VITE_API_URL=
VITE_API_URL=
