# MongoDB Connection URI for the Docker environment
# In development (with local SSH tunnel), use host.docker.internal to access the host's localhost port:
MONGO_URI=mongodb://host.docker.internal:27018/zoppertrack?directConnection=true

# In production, replace this with your remote MongoDB Atlas or server connection string:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/zoppertrack
